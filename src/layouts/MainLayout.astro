---
import Footer from '../components/Footer.astro';
import HeaderNavigation from '../components/HeaderNavigation.astro';

const { 
  title = "ISeekPrice - تتبع اسعار المنتجات ومقارنة العروض", 
  description = "قارن الأسعار بين المتاجر المختلفة، اكتشف أفضل العروض والخصومات، وتسوق أونلاين بذكاء.",
  type = "main" 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{title}</title>
    <meta name="description" content={description}>
    
    <meta content='7d7f763921' name='verify-admitad'/>  
    <meta content='4444cdf2f0a49fb484bf404640ddbd44' name='p:domain_verify'/>  
    <meta content='zwgupH08YoN_WM-XihJynuANAqHUsnLDSSenbcTktc8' name='google-site-verification'/>

    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content="/assets/banners/Iseekprice1.png">
    <meta property="og:url" content="https://www.iseekprice.com/">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@ISeekPrice">

    <script is:inline async src='https://www.googletagmanager.com/gtag/js?id=G-FRWKEMXVYT'></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FRWKEMXVYT');
    </script>

    <script type='application/ld+json' is:inline>
    { 
      "@context": "https://schema.org", 
      "@type": "WebSite", 
      "url": "https://www.iseekprice.com/", 
      "name": "ISeekPrice", 
      "potentialAction": { 
        "@type": "SearchAction", 
        "target": "https://www.iseekprice.com/p/search.html?q={search_term_string}", 
        "query-input": "required name=search_term_string" 
      } 
    }
    </script>

    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link href='/manifest.json' rel='manifest'/> 
  
    <link href='/css/main.css' rel='stylesheet'/> 
    {type === 'product' && <link href='/css/product.css' rel='stylesheet'/>}

    <style is:global>
        body, body * {
          font-family: 'Cairo', sans-serif !important;
          font-weight: 900;
          letter-spacing: 0;
          text-rendering: optimizeLegibility;
          -webkit-font-smoothing: antialiased;
        }

        .full-width-banner{width:100vw;position:relative;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;padding:60px 0;background:linear-gradient(135deg,#0f172a 0%,#2563eb 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:#fff;box-shadow:0 10px 25px rgb(0 0 0 / .1);z-index:10}.full-width-banner h2{font-size:clamp(1.5rem, 5vw, 2.5rem);margin-bottom:20px;font-weight:800;letter-spacing:-.5px}.banner-link{display:inline-block;background:#fff;color:#2563eb;padding:14px 35px;border-radius:50px;font-weight:700;text-decoration:none;transition:all 0.3s cubic-bezier(.4,0,.2,1);box-shadow:0 4px 12px rgb(0 0 0 / .15)}.banner-link:hover{transform:translateY(-3px) scale(1.05);box-shadow:0 8px 20px rgb(0 0 0 / .2);background:#f1f5f9}
    </style>
</head>
<body>

    <HeaderNavigation />

    <slot />

    <Footer />

    <script is:inline defer src='/js/general/worker.js'></script>  
    <script is:inline defer src='/js/general/grid.js'></script>  
    <script is:inline defer src='/js/general/corepress.js'></script>    
    <script is:inline defer src='/js/general/search.js'></script>

    {type === 'product' && (
      <>
        <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script is:inline defer src="/js/product/fetch.js"></script>
        <script is:inline defer src="/js/product/make.js"></script>
      </>
    )}

    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/js/general/sw.js')
            .then(reg => console.log('Service Worker Registered!', reg))
            .catch(err => console.error('Service Worker Failed!', err));
        });
      }
    </script>

</body>
</html>
